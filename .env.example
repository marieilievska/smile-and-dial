# Copy this file to .env.local and fill in the real values.
# Supabase project credentials — Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# E2E test accounts used by the Playwright suite (admin + member).
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_MEMBER_EMAIL=
E2E_MEMBER_PASSWORD=

# Twilio API key (Console > Account > API keys & tokens).
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# Set to "live" to run real (paid) Twilio Lookups during CSV import.
# Anything else — including blank — uses a free deterministic mock.
TWILIO_LOOKUP_MODE=
# Set to "live" to search and BUY real Twilio numbers (monthly cost).
# Anything else — including blank — uses a free deterministic mock.
TWILIO_LIVE=

# Set to "live" to push agent configs to the real ElevenLabs Convai API.
# Anything else — including blank — uses a free deterministic mock.
ELEVENLABS_LIVE=
# ElevenLabs API key — one shared account for the whole product.
# Set this in Vercel for production and in .env.local for dev. Round L1.
ELEVENLABS_API_KEY=

# Workspace-level ElevenLabs resources applied to every agent we create.
# The dictionary id and analysis model have baked-in defaults (the product
# runs on one ElevenLabs account), so these two only need a value to
# OVERRIDE the default (e.g. a staging account). Leave blank to use defaults.
# - Pronunciation dictionary id (brand/industry terms said correctly).
ELEVENLABS_PRONUNCIATION_DICTIONARY_ID=
# - Model that runs post-call analysis (data collection + evaluation).
ELEVENLABS_ANALYSIS_LLM=
# - Workspace post-call webhook id. NO default — create the webhook ONCE in
#   the ElevenLabs dashboard (Settings → Webhooks) pointing at our
#   /api/elevenlabs/post-call route, then paste its id here so every agent
#   reports transcript / audio / call-failure events to it.
ELEVENLABS_POST_CALL_WEBHOOK_ID=

# Public URL of the deployed app. Used to build webhook URLs we hand
# to Twilio (voice + status) and ElevenLabs (post-call). For dev,
# leave blank or use an ngrok tunnel.
NEXT_PUBLIC_APP_URL=
